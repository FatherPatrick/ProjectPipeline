# Database
DATABASE_URL=postgresql://user:password@localhost:5432/personal_data_dashboard
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Environment
ENVIRONMENT=development
DEBUG=True

# GitHub API
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_USERNAME=your_github_username

# Spotify API
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8000/auth/spotify/callback

# Steam API (Optional, for future integration)
STEAM_API_KEY=your_steam_api_key

# Scheduler
SCHEDULER_ENABLED=True
SCHEDULER_TIMEZONE=UTC

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Dashboard
DASHBOARD_PORT=8050
DASHBOARD_HOST=0.0.0.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Data Collection
GITHUB_BACKFILL_DAYS=730
SPOTIFY_BACKFILL_DAYS=730
DATA_REFRESH_INTERVAL_HOURS=168  # Weekly (7 days * 24 hours)
